{
  "meta": {
    "name": "air-gapped",
    "description": "Run pi without file system access"
  },
  "groups": {
    "include": ["node_runtime", "linux_temp_read"]
  },
  "filesystem": {
    "allow": [
      "~/.local/share/NuGet",
      "~/.nuget",
      "~/.pi/agent/"
    ],
    "read": [
      "/etc/gitconfig",
      "~/.cargo/bin",
      "~/.dotnet",
      "~/.gitconfig",
      "~/.local/share/bob",
      "~/projects/dotfiles/pi/"
    ]
  },
  "environment": {
    "allow_vars": [
      "HOME",
      "MCPC_HOME_DIR",
      "NONO_PROFILE",
      "PATH",
      "TERM"
    ]
  }
}
