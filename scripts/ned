#!/usr/bin/env -S nu --stdin

# ned: [n]vim s[ed]
# A sed-ish way to use nvim
@example "Edit stream" {echo "hello world" | ned "s/hello/hi"} --result "hi world"
@example "Edit file and output result without modifying it" {echo "hello world" > test.txt; ned "s/hello/hi" -f test.txt} --result "hi world"
@example "Edit file inplace with no output" {echo "hello world" > test.txt; ned -i "s/hello/hi" -f test.txt; cat test.txt} --result "hi world"
def --wrapped main [
  ...ex_cmds               # Params for nvim
  --file (-f):string = "-" # Read from file instead of stdin
  --in-place (-i)          # Modify file in place
] {
  if $in_place {
    ^nvim ...(format $ex_cmds) '+x' $file -l /dev/null
    | complete
    | ignore
  } else {
    ^nvim ...(format $ex_cmds) '+%print' $file -l /dev/null
  }
}

# Prefixing with a plus indicates that nvim should execute it as a cmd after
# config and first file.
def format [ex_cmds] {
  $ex_cmds
  | each { '+' + $in }
}
