#!/usr/bin/env -S nu --stdin

# Neovim sED
# sed: echo hi | sed s/hi/hello/
# ned: echo hi | ned +s/hi/hello
def --wrapped main [
  ...rest                 # Params for nvim
  --file (-f):string = "" # Read from file instead of stdin
  --in-place (-i)         # Modify file in place
] {
  if $file == "" {
    ^nvim ...$rest '+%print' - -l /dev/null
  } else if $in_place {
    ^nvim ...$rest '+x' $file -l /dev/null
    | complete
    | ignore
  } else {
    ^nvim ...$rest '+%print' $file -l /dev/null
  }
}

