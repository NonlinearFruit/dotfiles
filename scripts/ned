#!/usr/bin/env -S nu --stdin

# Neovim sED
# sed: echo hi | sed s/hi/hello/
# ned: echo hi | ned +s/hi/hello
def --wrapped main [
  ...ex_cmds               # Params for nvim
  --file (-f):string = "-" # Read from file instead of stdin
  --in-place (-i)          # Modify file in place
] {
  if $in_place {
    ^nvim ...(format $ex_cmds) '+x' $file -l /dev/null
    | complete
    | ignore
  } else {
    ^nvim ...(format $ex_cmds) '+%print' $file -l /dev/null
  }
}

# Prefixing with a plus indicates that nvim should execute it as a cmd after
# config and first file.
def format [ex_cmds] {
  $ex_cmds
  | each { '+' + $in }
}
